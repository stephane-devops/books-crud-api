{
    "name": "bref/books-crud-api",
    "description": "Bref-native Books CRUD API",
    "type": "project",
    "require": {
        "php": "^8.3",
        "aws/aws-sdk-php": "^3.300",
        "bref/bref": "^2.1",
        "slim/slim": "^4.0",
        "slim/psr7": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
